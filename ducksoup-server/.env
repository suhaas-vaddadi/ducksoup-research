# DuckSoup Local Dev Environment
# ================================

# Allow connections from localhost (Electron app and test pages)
DUCKSOUP_ALLOWED_WS_ORIGINS=http://localhost:8100,http://localhost:3000,http://localhost:4000,http://localhost:8888

# STUN servers for ICE candidate gathering (works fine locally)
DUCKSOUP_STUN_SERVER_URLS=stun:stun.l.google.com:19302,stun:stun3.l.google.com:19302

# Test page credentials
DUCKSOUP_TEST_LOGIN=admin
DUCKSOUP_TEST_PASSWORD=admin

# Logging
DUCKSOUP_LOG_STDOUT=true
DUCKSOUP_LOG_LEVEL=info
GST_PLUGIN_PATH=/app/plugins:/usr/lib/aarch64-linux-gnu/gstreamer-1.0
LD_LIBRARY_PATH=/app/plugins:/usr/lib/aarch64-linux-gnu
DUCKSOUP_DATA_FOLDER=/app/data

# GStreamer debug
GST_DEBUG=2,videodecoder:1
